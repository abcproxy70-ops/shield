# shieldnode v3.15.0 — пример конфигурации
#
# Этот файл ОПЦИОНАЛЕН. Если его НЕТ в /etc/shieldnode/shieldnode.conf
# — используются hardcoded дефолты в скрипте (те что закомментированы ниже).
#
# Установка:
#   sudo cp shieldnode.conf.example /etc/shieldnode/shieldnode.conf
#   sudo nano /etc/shieldnode/shieldnode.conf
#   sudo systemctl restart 'shieldnode-update@*.service'
#
# Альтернативно — все toggle'ы можно изменить через `sudo guard` →
# меню [s] settings (auto-sync, version check, mobile-RU, tor).
#
# Синтаксис: bash array. Чтобы для одного set'а было НЕСКОЛЬКО URL'ов —
# объединяй через запятую без пробелов.

# ==============================================================================
# v3.14.0: AUTO-SYNC FROM GITHUB
# ==============================================================================
# Каждые 6ч нода скачивает lists/custom.txt с github и заменяет локальный.
# Локальные дополнения оператора (эта нода) — в /etc/shieldnode/lists/custom-local.txt
# (НЕ трогается github sync'ом, объединяется с custom.txt в nft set).
#ENABLE_GITHUB_SYNC=1

# Раз в день нода проверяет github на новую версию shieldnode.sh.
# Если есть новая — guard CLI покажет [upgrade] баннер. Никаких авто-апгрейдов.
# Команды: 'sudo guard upgrade' (re-run installer), 'sudo guard check' (force).
#ENABLE_VERSION_CHECK=1

# ==============================================================================
# v3.15.0: MOBILE-RU AS WHITELIST (CGNAT-friendly relaxed limits)
# ==============================================================================
# Российские мобильные операторы дают CGNAT с 50-200 абонентами на 1 IP.
# При активной нагрузке такой IP может выдавать 600-1000 concurrent — что
# превышает стандартный ct=400. Mobile-RU whitelist даёт RELAXED лимиты:
#   - ct count:    400  → 1000   (CGNAT с 100-200 юзерами)
#   - newconn rate: 500/min → 2000/min, burst 1000 → 4000
#   - SYN/UDP rate-limit пропускаются для этих IPs (accept early)
#
# v3.15.0: список CIDR'ов берётся из github (lists/mobile-ru.txt), который
# автогенерируется раз в неделю через GitHub Actions из RIPEstat API.
# НИКАКИХ ключей или регистрации не нужно — обычный публичный blocklist.
#
# Включён по умолчанию. Можно отключить:
#ENABLE_RU_MOBILE_WHITELIST=0

# ==============================================================================
# v3.12.0: LOCAL BLOCKLISTS (file-based)
# ==============================================================================
# Путь к локальному .txt файлу для каждого set'а. Объединяется (union) с URL'ами.
# v3.14.0: custom поддерживает 2 файла через запятую — github sync + локальный.

#LOCAL_BLOCKLISTS=(
#    "scanner=/etc/shieldnode/lists/scanner.txt"
#    "threat=/etc/shieldnode/lists/threat.txt"
#    "tor=/etc/shieldnode/lists/tor.txt"
#    "custom=/etc/shieldnode/lists/custom.txt,/etc/shieldnode/lists/custom-local.txt"
#    "mobile_ru=/etc/shieldnode/lists/mobile-ru.txt"
#)

# ==============================================================================
# v3.12.0: REMOTE BLOCKLISTS (URL-based)
# ==============================================================================
# Несколько URL'ов через запятую — объединение для одного set'а.
# Если для set'а нет URL'ов — оставь "name=" (пустое значение).

#REMOTE_BLOCKLISTS=(
#    "scanner=https://raw.githubusercontent.com/shadow-netlab/traffic-guard-lists/refs/heads/main/public/antiscanner.list,https://raw.githubusercontent.com/shadow-netlab/traffic-guard-lists/refs/heads/main/public/government_networks.list,https://raw.githubusercontent.com/tread-lightly/CyberOK_Skipa_ips/main/lists/skipa_cidr.txt"
#    "threat=https://www.spamhaus.org/drop/drop.txt,https://iplists.firehol.org/files/firehol_level1.netset"
#    "tor=https://check.torproject.org/torbulkexitlist"
#    "custom="
#    "mobile_ru=https://raw.githubusercontent.com/abcproxy70-ops/shield/main/lists/mobile-ru.txt"
#)

# ==============================================================================
# UPDATE INTERVALS (формат systemd OnUnitActiveSec)
# ==============================================================================
#SCANNER_UPDATE_INTERVAL="6h"
#THREAT_UPDATE_INTERVAL="1d"
#TOR_UPDATE_INTERVAL="1h"
#CUSTOM_UPDATE_INTERVAL="6h"
#MOBILE_RU_UPDATE_INTERVAL="1d"   # github cron обновляет раз в неделю,
                                   # клиент чекает раз в день

# ==============================================================================
# MIN ENTRIES (sanity check против corrupted upstream)
# ==============================================================================
#MIN_ENTRIES_SCANNER=100
#MIN_ENTRIES_THREAT=500
#MIN_ENTRIES_TOR=100
#MIN_ENTRIES_CUSTOM=0
#MIN_ENTRIES_MOBILE_RU=100

#FAIL_THRESHOLD=3

# ==============================================================================
# v3.11: TOR EXIT BLOCKLIST
# ==============================================================================
# Блокирует подключения Tor exit nodes. По умолчанию ОТКЛЮЧЕНО — операторы
# которые хостят Tor → VPN bridge для параноиков должны оставлять выключенным.
#BLOCK_TOR=0

# ==============================================================================
# Примеры кастомизации
# ==============================================================================

# Пример 1: offline-mode (только локальные файлы)
#REMOTE_BLOCKLISTS=("scanner=" "threat=" "tor=" "custom=" "mobile_ru=")

# Пример 2: реже обновлять (для слабого сервера)
#SCANNER_UPDATE_INTERVAL="12h"
#THREAT_UPDATE_INTERVAL="2d"

# Пример 3: свой источник mobile-RU CIDR'ов (если форкнул репо)
#REMOTE_BLOCKLISTS=(
#    "mobile_ru=https://raw.githubusercontent.com/MY_FORK/shield/main/lists/mobile-ru.txt"
#)
